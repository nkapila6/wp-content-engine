# OPENROUTER KEYS
OPENROUTER_API_KEY=
# OPENROUTER_MODEL=openai/gpt-4.1-nano
OPENROUTER_MODEL=google/gemini-2.5-flash

# CONDENSER LIMIT
CONDENSER_TOKEN_LIMIT=3000

# KNOWLEDGE BASE
# KB_ROOT=~/Code/wp-content-engine/knowledge_base
KB_ROOT=
BRAND_NAME=Your Brand Name

# WORDPRESS (set to enable WP push)
WP_URL=https://your-wordpress-site.com
WP_USER=your-username
# this is a WordPress app password, not a regular password
WP_APP_PASSWORD=your-app-password
WP_POST_STATUS=draft
WP_DEFAULT_CATEGORY=your-default-category
